# EKOS v1.0 Environment Configuration Template
# Copy this file to .env and fill in all required values.
# DO NOT commit the .env file to source control.

# ── Application ────────────────────────────────────────────────────────────
APP_NAME="EKOS - Enterprise Knowledge Operating System"
APP_ENVIRONMENT=production
APP_DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_HEX

# ── Database (PostgreSQL + pgvector) ───────────────────────────────────────
DATABASE_URL=postgresql://ekos_user:CHANGE_ME@postgres:5432/ekos_db
POSTGRES_PASSWORD=CHANGE_ME

# ── Neo4j (Knowledge Graph) ────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME

# ── Redis (Distributed Cache + Events) ────────────────────────────────────
REDIS_URI=redis://redis:6379/0

# ── AI Providers (Only one is required) ───────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=CHANGE_ME
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── JWT Authentication ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_HEX
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Server ────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_WINDOW_SECONDS=60
