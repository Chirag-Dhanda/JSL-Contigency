{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Install Dependencies",
      "type": "shell",
      "command": "python",
      "args": ["-m", "pip", "install", "-r", "requirements.txt"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: Start API",
      "type": "shell",
      "command": "python",
      "args": ["-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Backend: Compile Check",
      "type": "shell",
      "command": "python",
      "args": ["-m", "compileall", "."],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Install Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}/frontend_app"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Start App",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"],
      "options": {
        "cwd": "${workspaceFolder}/frontend_app"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: Lint",
      "type": "shell",
      "command": "npm",
      "args": ["run", "lint"],
      "options": {
        "cwd": "${workspaceFolder}/frontend_app"
      },
      "problemMatcher": []
    },
    {
      "label": "Dev: Full Stack",
      "dependsOn": [
        "Backend: Start API",
        "Frontend: Start App"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
